# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/open_langgraph
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
#
# Checkpointer backend (auto/postgres/sqlite/memory)
CHECKPOINTER_BACKEND=auto
# CHECKPOINTER_DSN=postgresql://user:password@localhost:5432/open_langgraph
# CHECKPOINTER_OPTIONS={}

# Streaming (broker + event storage)
# BROKER_QUEUE_MAXSIZE=1000
# BROKER_BACKPRESSURE_POLICY=block  # block, drop_oldest
# EVENT_STORE_BATCH_SIZE=50

# Authentication (extensible)
AUTH_TYPE=noop  # noop, custom

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Config (optional)
# Override the default graphs config file path (absolute or relative).
# If not set, the service looks for ./open_langgraph.json then ./langgraph.json
OPEN_LANGGRAPH_CONFIG=./open_langgraph.json

# LLM Providers
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# TOGETHER_API_KEY=...

LANGFUSE_LOGGING=true
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenTelemetry (pip install open-langgraph-platform[otel] required)
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=open-langgraph
# OTEL_SERVICE_VERSION=0.1.0
# OTEL_DEPLOYMENT_ENVIRONMENT=development
# OTEL_INSECURE=true
