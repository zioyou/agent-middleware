# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/open_langgraph
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
#
# Checkpointer backend (auto/postgres/sqlite/memory)
CHECKPOINTER_BACKEND=auto
# CHECKPOINTER_DSN=postgresql://user:password@localhost:5432/open_langgraph
# CHECKPOINTER_OPTIONS={}

# Streaming (broker + event storage)
# BROKER_QUEUE_MAXSIZE=1000
# BROKER_BACKPRESSURE_POLICY=block  # block, drop_oldest
# EVENT_STORE_BATCH_SIZE=50

# Authentication (extensible)
AUTH_TYPE=noop  # noop, custom

# Server
HOST=0.0.0.0
PORT=8002
DEBUG=true

# Config (optional)
# Override the default graphs config file path (absolute or relative).
# If not set, the service looks for ./agents.json then ./langgraph.json
OPEN_LANGGRAPH_CONFIG=./agents.json

# LLM Providers (기본 LLM 사용 시 필요)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TOGETHER_API_KEY=xxxxxxxxxxxxxxxx

LANGFUSE_LOGGING=true
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenTelemetry (pip install agent-middleware[otel] required)
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=open-langgraph
# OTEL_SERVICE_VERSION=0.1.0
# OTEL_DEPLOYMENT_ENVIRONMENT=development
# OTEL_INSECURE=true

# CORS Settings for Agent Chat UI
CORS_ALLOW_ALL=true

# ============================================================================
# LLM Model Configuration
# 🔄 모델 전환 스위치: 아래 MODEL 변수만 변경하면 사용할 모델이 바뀝니다.
# ============================================================================

# ✅ 현재 활성화: LM Studio 로컬 모델 (기본값)
MODEL=lmstudio/openai/gpt-oss-20b
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1

# 다른 모델로 전환하려면 위의 MODEL 줄을 주석 처리하고 아래 중 하나를 활성화:
# MODEL=google_genai/gemini-2.0-flash-lite
# [구글 제미나이 API 키 발급처: https://aistudio.google.com/app/apikey]
GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Tools Configuration (에이전트 외부 도구 연동)
# ============================================================================

# [Tavily Search API: https://app.tavily.com/]
# 용도: 에이전트가 인터넷 검색(웹 서칭) 도구를 사용할 때 필요한 API 키
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [Google OAuth 설정: GCP Console (https://console.cloud.google.com/) -> API & Services -> Credentials]
# 용도: 프론트엔드 설정창 도달 전 기본값을 세팅하거나 백엔드에서 Google API(메일, 캘린더)를 쓰기 위한 키
GOOGLE_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:8002/auth/google/callback

# [Slack App Configuration: https://api.slack.com/apps]
# 용도: Slack Webhook 연동 및 인터랙티브 모달(UI 응답) 등을 지원하기 위한 봇 토큰
# 발급처: 자신이 만든 앱의 Incoming Webhooks 메뉴에서 확인
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE_ID/YOUR_CHANNEL_ID/YOUR_WEBHOOK_TOKEN
# 발급처: 자신이 만든 앱의 OAuth & Permissions 메뉴에서 Bot User OAuth Token 복사 (xoxb-...)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxx-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
